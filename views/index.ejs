<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini Message Board</title>
  </head>

  <body>
    <h1>Message Board</h1>

    <a href="new">Add New Message</a>

    <ul>
      <% for (let i = 0; i < messages.length; i++) { %>
        <li>
          <strong><%= messages[i].user %></strong>
          <p><%= messages[i].text %></p>
          <small><%= messages[i].added %></small>
        </li>
      <% } %>
    </ul>
  </body>
</html>